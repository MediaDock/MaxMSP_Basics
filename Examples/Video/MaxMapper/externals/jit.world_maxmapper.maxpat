																	"code" : "onSegment(p, q, r) \r\n{\r\n\tif (q.x <= max(p.x, r.x) && q.x >= min(p.x, r.x) &&\r\n\t\tq.y <= max(p.y, r.y) && q.y >= min(p.y, r.y))\r\n\t{\r\n\t\treturn 1;\r\n\t}\r\n\treturn 0;\r\n}\r\n\r\norientation(p, q, r)\r\n{\r\n\tval = (q.y - p.y) * (r.x - q.x) - (q.x - p.x) * (r.y - q.y);\r\n\tif (val == 0) return 0; // colinear\r\n\telse return (val > 0) ? 1 : 2; // clock or counterclock wise\r\n}\r\n\r\ndoIntersect(vertex, nextVertex, point, ray)\r\n{\r\n\to1 = orientation(vertex, nextVertex, point);\r\n\to2 = orientation(vertex, nextVertex, ray);\r\n\to3 = orientation(point, ray, vertex);\r\n\to4 = orientation(point, ray, nextVertex);\r\n\t\r\n\tif (o1 != o2 && o3 != o4) return 1; // General case\r\n\t\r\n\t// Special cases\r\n\telse if (o1 == 0 && onSegment(vertex, point, nextVertex)) return 1;\r\n\telse if (o2 == 0 && onSegment(vertex, ray, nextVertex)) return 1;\r\n\telse if (o3 == 0 && onSegment(point, vertex, ray)) return 1;\r\n\telse if (o4 == 0 && onSegment(point, nextVertex, ray)) return 1;\r\n\t\r\n\telse return 0; // doesn't fall in any of the above cases\r\n}\r\n\r\nfrom1DTo2D(k, width) \r\n{\r\n\tx = k % width;\r\n\ty = floor(k / width);\r\n\treturn vec(x, y);\r\n}\r\n\r\nParam windowRatio(1.0);\r\nParam verticesNumber(4);\r\n\r\np = vec(snorm.x*windowRatio, snorm.y*-1.0);\r\n\r\nextreme = vec(10000, p.y);\r\n\t\r\ncount = 0;\r\n\t\r\nfor (k = 0; k < verticesNumber; k+=1) \r\n{\t\r\n\tpolygon = nearest(in1, vec(k/(dim.x-1), 0)).xy;\r\n\r\n\tpolygonNext = nearest(in1, vec((((k+1)%verticesNumber))/(dim.x-1), 0)).xy;\r\n\t\t\r\n\tif (doIntersect(polygon, polygonNext, p, extreme))\r\n\t{\r\n\t\tif (orientation(polygon, p, polygonNext) == 0)\r\n\t\t\tout1 = onSegment(polygon, p, polygonNext);\r\n\t\t\t\t\r\n\t\tcount+=1;\r\n\t}\r\n}\r\n\r\nout1 = (count % 2 == 1);\r\n",
